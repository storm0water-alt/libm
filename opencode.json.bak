{
  "$schema": "https://opencode.ai/config.json",
  "workingDirectory": "archive-management",
  "theme": "auto",
  "rules": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      ".next/**"
    ],
    "only": [
      "archive-management/**",
      "archive-management-ui/src/**"
    ]
  },
  "commands": {
    "test": {
      "description": "Run tests in archive-management",
      "command": "cd archive-management && npm run test"
    },
    "test:e2e": {
      "description": "Run E2E tests in archive-management",
      "command": "cd archive-management && npm run test:e2e"
    },
    "dev": {
      "description": "Start development server",
      "command": "cd archive-management && npm run dev"
    },
    "build": {
      "description": "Build the project",
      "command": "cd archive-management && npm run build"
    },
    "lint": {
      "description": "Run linting",
      "command": "cd archive-management && npm run lint"
    }
  }
}
